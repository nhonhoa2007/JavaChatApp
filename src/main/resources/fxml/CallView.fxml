<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.geometry.Insets?>

<StackPane fx:id="rootPane" xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.client.controller.CallViewController"
           style="-fx-background-color: #0f172a;"
           prefWidth="320" prefHeight="420">

    <!-- video từ người gọi còn lại -->
    <ImageView fx:id="imgRemoteVideo" preserveRatio="true" visible="false" />

    <!-- lớp thông tin và bố cục thoại -->
    <VBox alignment="CENTER" spacing="16.0" style="-fx-background-color: rgba(15, 23, 42, 0.45);">
        <padding>
            <Insets bottom="30.0" left="20.0" right="20.0" top="30.0"/>
        </padding>

        <!-- trạng thái -->
        <Label fx:id="lblStatus" text="Đang kết nối..."
               style="-fx-font-size: 13px; -fx-text-fill: #94a3b8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.8), 4, 0, 0, 0);"/>

        <!-- avatar khi gọi thoại hoặc tắt camera -->
        <Label fx:id="lblAvatar" text="👤" style="-fx-font-size: 64px;"/>

        <!-- tên người gọi còn lại -->
        <Label fx:id="lblPeerName" text="Username"
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.8), 4, 0, 0, 0);"/>

        <!-- bộ đếm thời gian -->
        <Label fx:id="lblTimer" text="00:00"
               style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #22c55e; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.8), 4, 0, 0, 0);"/>

        <!-- loại cuộc gọi -->
        <Label fx:id="lblCallType" text="Voice Call"
               style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>

        <VBox VBox.vgrow="ALWAYS"/>

        <!-- điều khiển cuộc gọi -->
        <HBox alignment="CENTER" spacing="20.0">
            <Button fx:id="btnMute" text="🎤" onAction="#handleMute"
                    style="-fx-background-color: #334155; -fx-text-fill: white; -fx-font-size: 20px;
                           -fx-min-width: 56; -fx-min-height: 56; -fx-background-radius: 28; -fx-cursor: hand;"/>

            <Button fx:id="btnCamera" text="📷" onAction="#handleCameraToggle" visible="false" managed="false"
                    style="-fx-background-color: #334155; -fx-text-fill: white; -fx-font-size: 20px;
                           -fx-min-width: 56; -fx-min-height: 56; -fx-background-radius: 28; -fx-cursor: hand;"/>

            <Button fx:id="btnEnd" text="📵" onAction="#handleEnd"
                    style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 20px;
                           -fx-min-width: 64; -fx-min-height: 64; -fx-background-radius: 32; -fx-cursor: hand;"/>
        </HBox>
    </VBox>

    <!-- preview video cục bộ dạng nổi -->
    <AnchorPane pickOnBounds="false">
        <ImageView fx:id="imgLocalVideo" fitWidth="120.0" fitHeight="90.0" preserveRatio="true" visible="false"
                   AnchorPane.bottomAnchor="110.0" AnchorPane.rightAnchor="15.0"
                   style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 10, 0, 0, 0); -fx-border-color: #475569; -fx-border-width: 2px; -fx-border-radius: 4px;"/>
    </AnchorPane>

</StackPane>
