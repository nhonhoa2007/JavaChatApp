<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="550.0" prefWidth="800.0" styleClass="chat-root" stylesheets="@../styles/chat.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.client.controller.ChatController">
    <left>
        <VBox prefWidth="64.0" spacing="12.0" styleClass="side-nav">
            <Button fx:id="btnNavSearch" contentDisplay="GRAPHIC_ONLY" onAction="#handleShowSearchView" styleClass="nav-button" />
            <Button fx:id="btnNavChat" contentDisplay="GRAPHIC_ONLY" onAction="#handleShowChatView" styleClass="nav-button" />
            <Button fx:id="btnNavContacts" contentDisplay="GRAPHIC_ONLY" onAction="#handleShowContactsView" styleClass="nav-button" />
            <Button fx:id="btnNavGroups" contentDisplay="GRAPHIC_ONLY" onAction="#handleShowGroupsView" styleClass="nav-button" />
            <Button fx:id="btnNavProfile" contentDisplay="GRAPHIC_ONLY" onAction="#handleShowProfileView" styleClass="nav-button" />
            <Button fx:id="btnAdmin" contentDisplay="GRAPHIC_ONLY" onAction="#handleShowAdminView" styleClass="nav-button" visible="false" managed="false" />
            <Region VBox.vgrow="ALWAYS" />
            <Button fx:id="btnNavLogout" contentDisplay="GRAPHIC_ONLY" onAction="#handleLogout" styleClass="nav-button" style="-fx-text-fill: #ef4444;" />
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentStack" styleClass="content-stack">
            <!-- view tìm kiếm -->
            <fx:include fx:id="viewSearch" source="SearchView.fxml" />

            <!-- view khung chat -->
            <fx:include fx:id="viewChat" source="ChatWorkspaceView.fxml" />

            <!-- view danh bạ -->
            <fx:include fx:id="viewContacts" source="ContactsView.fxml" />

            <!-- view nhóm -->
            <fx:include fx:id="viewGroups" source="GroupsView.fxml" />

            <!-- view hồ sơ -->
            <fx:include fx:id="viewProfile" source="ProfileView.fxml" />

            <!-- view admin -->
            <fx:include fx:id="viewAdmin" source="AdminView.fxml" />
        </StackPane>
    </center>
</BorderPane>
