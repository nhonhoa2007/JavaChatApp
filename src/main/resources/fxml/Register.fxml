<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="16.0" stylesheets="@../styles/chat.css" styleClass="chat-root" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.client.controller.RegisterController" style="-fx-background-color: #f6f8fb;">

    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
    </padding>

    <Label text="Đăng ký tài khoản" styleClass="view-title" style="-fx-font-size: 22px; -fx-margin-bottom: 10px;"/>

    <TextField fx:id="txtUsername" promptText="Username" styleClass="app-input" style="-fx-pref-width: 240px; -fx-pref-height: 38px;"/>

    <TextField fx:id="txtFullName" promptText="Full Name" styleClass="app-input" style="-fx-pref-width: 240px; -fx-pref-height: 38px;"/>

    <PasswordField fx:id="txtPassword" promptText="Password" styleClass="app-input" style="-fx-pref-width: 240px; -fx-pref-height: 38px;"/>

    <Label fx:id="lblStatus" textFill="RED" wrapText="true" maxWidth="240" style="-fx-font-size: 12px;"/>

    <Button text="Đăng ký" onAction="#handleRegister" styleClass="primary-button" style="-fx-pref-width: 240px; -fx-pref-height: 40px; -fx-cursor: hand;"/>

    <Button text="Quay lại Đăng nhập" onAction="#goBackToLogin" style="-fx-background-color: transparent; -fx-text-fill: #2563eb; -fx-underline: true; -fx-cursor: hand; -fx-font-weight: bold;"/>

</VBox>
